      <Option name="params" type="Map">
        <Option name="INPUT" type="List">
          <Option type="Map">
            <Option name="expression" value="with_variable('m_per_mm',&#xa;&#x9;1.1*((&#xa;    @Laag_uit_bereik_maken__extent__OUTPUT_maxx - &#xa;    @Laag_uit_bereik_maken__extent__OUTPUT_minx&#xa;  )) / @printbedbreedte_mm,&#xa;  &#xa;  with_variable('ronde_afstand',&#xa;    CASE&#xa;      WHEN 50      / @m_per_mm BETWEEN 20 AND 50 THEN 50&#xa;      WHEN 100     / @m_per_mm BETWEEN 20 AND 50 THEN 100&#xa;      WHEN 500     / @m_per_mm BETWEEN 20 AND 50 THEN 500&#xa;      WHEN 1000    / @m_per_mm BETWEEN 20 AND 50 THEN 1000&#xa;      WHEN 2000    / @m_per_mm BETWEEN 20 AND 50 THEN 2000&#xa;      WHEN 5000    / @m_per_mm BETWEEN 20 AND 50 THEN 5000&#xa;      WHEN 10000   / @m_per_mm BETWEEN 20 AND 50 THEN 10000&#xd;&#xa;&#x9;  WHEN 15000  /  @m_per_mm BETWEEN 20 AND 50 THEN 15000&#xd;&#xa;&#x9;  WHEN 20000  /  @m_per_mm BETWEEN 20 AND 50 THEN 20000&#xd;&#xa;&#x9;  WHEN 25000  /  @m_per_mm BETWEEN 20 AND 50 THEN 25000&#xa;      WHEN 50000   / @m_per_mm BETWEEN 20 AND 50 THEN 50000&#xd;&#xa;&#x9;  WHEN 100000  / @m_per_mm BETWEEN 20 AND 50 THEN 100000&#xa;      WHEN 200000  / @m_per_mm BETWEEN 20 AND 50 THEN 200000&#xa;      WHEN 500000  / @m_per_mm BETWEEN 20 AND 50 THEN 500000&#xa;      WHEN 1000000 / @m_per_mm BETWEEN 20 AND 50 THEN 1000000&#xa;      WHEN 2000000 / @m_per_mm BETWEEN 20 AND 50 THEN 2000000&#xa;      ELSE 2000000&#xa;    END,&#xa;    @ronde_afstand&#xa;  )&#xa;)" type="QString"/>
            <Option name="source" value="3" type="int"/>
          </Option>
        </Option>
      </Option>
    </Option>
